# Zkopíruj tento soubor jako ".env" a vlož svůj OpenAI API klíč.
# Klíč získáš na https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Volitelně: model pro čtení obrázků (gpt-4o-mini je nejlevnější s "vision")
OPENAI_MODEL=gpt-4o-mini

# Volitelně: port, na kterém poběží aplikace
PORT=3000

# --- Databáze ---
# Lokálně (npm start na tvém PC) nemusíš nic vyplňovat - použije se
# soubor data/training.db automaticky.
#
# Pro nasazení na Vercel potřebuješ vzdálenou Turso databázi (zdarma):
#   1) npx -y @libsql/client@latest --help   (jen ověření že je libsql dostupné)
#   2) Vytvoř si účet na https://turso.tech a databázi (přes web nebo Turso CLI)
#   3) Zkopíruj "Database URL" a vytvoř "Auth token", vlož sem:
# TURSO_DATABASE_URL=libsql://tvoje-db-nazev.turso.io
# TURSO_AUTH_TOKEN=tvuj-token
