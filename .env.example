# Zkopíruj tento soubor jako ".env" a vlož svůj OpenAI API klíč.
# Klíč získáš na https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Volitelně: model pro čtení obrázků (gpt-4o-mini je nejlevnější s "vision")
OPENAI_MODEL=gpt-4o-mini

# Volitelně: port, na kterém poběží aplikace
PORT=3000

# --- Databáze (Turso / libSQL) ---
# Vyžadováno vždy - lokálně i na Vercelu se appka připojuje
# ke stejné vzdálené Turso databázi (zdarma pro osobní použití):
#   1) Vytvoř si účet na https://turso.tech a databázi (přes web dashboard)
#   2) Zkopíruj "Database URL" a vytvoř "Auth token", vlož sem:
TURSO_DATABASE_URL=libsql://tvoje-db-nazev.turso.io
TURSO_AUTH_TOKEN=tvuj-token
